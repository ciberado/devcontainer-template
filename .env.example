# Tailscale authentication key — optional.
# Leave empty to skip Tailscale setup entirely.
# Generate one at https://login.tailscale.com/admin/settings/authkeys
TAILSCALE_AUTHKEY=

# Project name — optional. Used as the Tailscale node hostname: vs-<PROJECT_NAME>.
# Only meaningful when TAILSCALE_AUTHKEY is set.
PROJECT_NAME=
